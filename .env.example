APP_NAME="ALG Marketing Platform"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://marketing.alg3pl.com

DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=alg_marketing
DB_USERNAME=
DB_PASSWORD=

# Google APIs
GOOGLE_APPLICATION_CREDENTIALS=storage/app/google-credentials.json
GOOGLE_ANALYTICS_ACCOUNT_ID=319098934

# Email (SMTP via cPanel)
MAIL_MAILER=smtp
MAIL_HOST=mail.alg3pl.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=marketing@alg3pl.com
MAIL_FROM_NAME="ALG Marketing"

# WhatsApp Business API
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_VERIFY_TOKEN=

# Meta (Facebook/Instagram)
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=

# Claude API (for AI features)
ANTHROPIC_API_KEY=

# Queue
QUEUE_CONNECTION=database

# Cache
CACHE_DRIVER=file
SESSION_DRIVER=file

# Login helper (dev convenience — shows clickable credentials under /admin login)
# SET TO false IN PRODUCTION. Never commit real credentials.
SHOW_LOGIN_HELPER=false
ADMIN_EMAIL=
ADMIN_PASSWORD=
